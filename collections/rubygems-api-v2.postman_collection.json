  "item": [
    {
      "id": "7feb86fa-3245-46e1-a888-8c5a25f65f4f",
      "name": "Versions",
      "description": {
        "content": "Endpoints for querying detailed version information for specific gem versions, including metadata, dependencies, checksums, and platform-specific builds.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "f82cd969-484c-45f8-a6fa-4ce75eac56de",
          "name": "Get Gem Version Details",
          "request": {
            "name": "Get Gem Version Details",
            "description": {
              "content": "Returns detailed information about a specific gem version, including name, version number, download counts, platform, authors, description, dependencies, URIs, timestamps, checksums, and metadata. Optionally filter by platform using the platform query parameter.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "rubygems",
                ":gemName",
                "versions",
                "{{versionNumber}}.json"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "platform",
                  "value": "<string>",
                  "description": "Filter by platform. Common values include ruby, java, and x86_64-linux. If not specified, defaults to the ruby platform."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "gemName",
                  "description": "(Required) The name of the gem"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
