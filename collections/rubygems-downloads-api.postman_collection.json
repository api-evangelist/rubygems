        {
          "id": "4bc95f06-1549-4d7b-84ad-2479323e6212",
          "name": "Get Version Download Counts",
          "request": {
            "name": "Get Version Download Counts",
            "description": {
              "content": "Returns download count statistics for a specific gem version. The path parameter combines the gem name and version number with a hyphen separator (e.g., rails-7.0.0). Returns both the version- specific download count and the total download count across all versions of the gem.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "downloads",
                "{{gemNameVersion}}.json"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
