  "info": {
    "_postman_id": "a7675224-1b97-45b4-9bcf-8a0e571c530f",
    "name": "RubyGems Downloads API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The RubyGems Downloads API provides access to download count statistics for gems hosted on RubyGems.org. Developers can retrieve total download counts for specific gems and individual gem versions. This data is commonly used to gauge gem popularity, generate usage reports, and build dashboards that track adoption trends across the Ruby package ecosystem.\n\nContact Support:\n Name: RubyGems.org Support",
      "type": "text/plain"
    }
  }
