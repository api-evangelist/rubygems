          "name": "Get Total Downloads",
          "request": {
            "name": "Get Total Downloads",
            "description": {
              "content": "Returns the total number of gem downloads across all gems on RubyGems.org. This provides a single aggregate count of all gem installations ever recorded.",
              "type": "text/plain"
            },
            "url": {
              "path": [
