  "info": {
    "_postman_id": "09e6e55b-55d4-46a8-9843-67277a2e3715",
    "name": "RubyGems Webhooks API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The RubyGems Webhooks API enables developers to register, list, test, and remove webhook subscriptions that fire when gems are pushed to RubyGems.org. Webhooks can be configured for specific gems or applied globally using a wildcard to receive notifications for all gem pushes. Each webhook request includes an Authorization header for verification, allowing downstream systems to confirm the notification originated from RubyGems.org.\n\nContact Support:\n Name: RubyGems.org Support",
      "type": "text/plain"
    }
  }
